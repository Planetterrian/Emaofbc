# EMA of BC Platform - Production Environment Variables (TEMPLATE)
# Copy this file to .env.production.local (git-ignored) and fill in real values.
# These same values must also be added in Vercel -> Settings -> Environment Variables.

# ---- Supabase (Production) ----
NEXT_PUBLIC_SUPABASE_URL=https://[project-id].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Stripe (Live) ----
STRIPE_SECRET_KEY=sk_live_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ---- Email (Resend) ----
RESEND_API_KEY=your-resend-api-key

# ---- App URLs ----
NEXT_PUBLIC_APP_URL=https://emaofbc.com
NEXT_PUBLIC_SITE_URL=https://emaofbc.com

# ---- AI (xAI Grok) ----
XAI_API_KEY=your-xai-api-key
XAI_MODEL=grok-latest

# ---- Security / Jobs ----
NOTIFICATION_API_KEY=generate-32-char-random-string
CRON_SECRET=generate-32-char-random-string

# ---- Optional: Monitoring / Analytics ----
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GA_ID=
